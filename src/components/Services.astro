---

<section id="servicios" class="bg-base-200 py-20">
	<div class="mx-auto max-w-6xl px-4">
		<div class="text-center" data-reveal>
			<span class="badge badge-outline badge-primary">Servicios</span>
			<h2 class="mt-3 text-3xl font-bold sm:text-4xl">Qué hacemos</h2>
			<p class="mx-auto mt-3 max-w-xl opacity-70">
				Soluciones de tecnología de punta a punta: del levantamiento de
				requerimientos a la operación y el soporte.
			</p>
		</div>
		<div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{services.map((service, index) => (
				<div class="card bg-base-100 transition-shadow hover:shadow-lg" data-reveal style={`--reveal-delay: ${(index % 3) * 90}ms`}>
					<div class="card-body">
						<div class="w-fit rounded-box bg-primary/10 p-3 text-primary">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon} />
							</svg>
						</div>
						<h3 class="card-title mt-2">{service.title}</h3>
						<p class="opacity-70">{service.description}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
