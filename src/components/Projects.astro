---
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
	.filter(({ data }) => data.ambiente !== "Levantamiento Requerimiento")
	.sort(
		(a, b) =>
			Number(b.data.featured) - Number(a.data.featured) ||
			a.data.order - b.data.order,
	);

const groups = [
	{
		title: "Operación",
		items: projects.filter(({ data }) => data.tipo === "Operacion"),
	},
	{
		title: "Apoyo",
		items: projects.filter(({ data }) => data.tipo === "Apoyo"),
	},
];

const ambienteBadge = (ambiente?: string) => {
	switch (ambiente) {
		case "Producción":
			return "badge-soft badge-success";
		case "Pruebas":
			return "badge-soft badge-warning";
		case "Desarrollo":
			return "badge-soft badge-info";
		default:
			return "badge-ghost";
	}
};
---

<section id="proyectos" class="bg-base-100 py-20">
	<div class="mx-auto max-w-6xl px-4">
		<div class="text-center" data-reveal>
			<span class="badge badge-outline badge-primary">Portafolio</span>
			<h2 class="mt-3 text-3xl font-bold sm:text-4xl">Nuestros productos</h2>
			<p class="mx-auto mt-3 max-w-xl opacity-70">
				Productos desarrollados
			</p>
		</div>
		<div role="tablist" class="tabs tabs-border mt-10 justify-center">
			{groups.map((group, index) => (
				<>
					<input
						type="radio"
						name="proyectos_tabs"
						role="tab"
						class="tab text-base font-medium"
						aria-label={`${group.title} (${group.items.length})`}
						checked={index === 0}
					/>
					<div role="tabpanel" class="tab-content pt-10">
						<div class="columns-1 sm:columns-2 lg:columns-3 gap-6">
							{group.items.map(({ data }, index) => {
								const tecnologias = data.tecnologias.filter(
									(tec) => tec !== data.ambiente,
								);
								const Card = data.url ? "a" : "article";
								const linkProps = data.url
									? { href: data.url, target: "_blank", rel: "noopener noreferrer" }
									: {};
								return (
									<Card
										{...linkProps}
										data-reveal
										style={`--reveal-delay: ${(index % 3) * 90}ms`}
										class:list={[
											"break-inside-avoid mb-6 card card-border border-base-300 bg-base-100 transition-shadow hover:shadow-lg",
											data.url && "cursor-pointer hover:border-primary/50",
										]}
									>
										{data.image && (
											<figure>
												<img src={data.image} alt={data.producto} class="h-auto max-w-full" loading="lazy" />
											</figure>
										)}
										<div class="card-body gap-3">
											<div class="flex flex-wrap items-center justify-between gap-2">
												<h3 class="card-title text-lg">
													{data.producto}
													{data.featured && <span class="badge badge-accent badge-sm">Destacado</span>}
												</h3>
												{data.ambiente && (
													<span class={`badge badge-sm ${ambienteBadge(data.ambiente)}`}>{data.ambiente}</span>
												)}
											</div>
											{data.talentoHumano && (
												<div>
													<p class="text-xs font-semibold uppercase tracking-wider opacity-50">Talento humano</p>
													<ul class="mt-1 space-y-0.5 text-sm opacity-80">
														{data.talentoHumano.split(" · ").map((persona) => (
															<li>{persona}</li>
														))}
													</ul>
												</div>
											)}
											{data.soporte && (
												<div>
													<p class="text-xs font-semibold uppercase tracking-wider opacity-50">Soporte</p>
													<p class="mt-1 text-sm opacity-80">{data.soporte}</p>
												</div>
											)}
											{data.caracteristicaMaquina && (
												<div>
													<p class="text-xs font-semibold uppercase tracking-wider opacity-50">Característica de la máquina</p>
													<p class="mt-1 text-sm opacity-80">{data.caracteristicaMaquina}</p>
												</div>
											)}
											{(tecnologias.length > 0 || data.maquinas.length > 0) && (
												<div class="mt-1 flex flex-wrap gap-1.5">
													{tecnologias.map((tec) => (
														<span class="badge badge-ghost badge-sm">{tec}</span>
													))}
													{data.maquinas.map((maquina) => (
														<span class="badge badge-outline badge-sm">{maquina}</span>
													))}
												</div>
											)}
										</div>
									</Card>
								);
							})}
						</div>
					</div>
				</>
			))}
		</div>
	</div>
</section>
