---
// TODO: reemplazar con los datos reales del área de TI de AGM Desarrollos
const email = "sistemas@agmdesarrollos.com";


const canales = [
	{
		title: "Mesa de ayuda GLPI",
		detail: "Soporte de las aplicaciones en producción",
	},
	{
		title: "Correo electrónico",
		detail: "Casos de soporte y solicitudes generales",
	},
	{
		title: "Analistas de requerimientos",
		detail: "Nuevas aplicaciones y mejoras a las existentes",
	},
];
---

<section id="contacto" class="bg-neutral py-20 text-neutral-content">
	<div class="mx-auto grid max-w-6xl gap-12 px-4 lg:grid-cols-2">
		<div data-reveal>
			<span class="badge badge-outline border-neutral-content/40 text-neutral-content">Contacto</span>
			<h2 class="mt-3 text-3xl font-bold sm:text-4xl">¿Necesitas una aplicación o soporte?</h2>
			<p class="mt-3 max-w-xl opacity-80">
				Cuéntale tu requerimiento al equipo de TI: una aplicación nueva, una mejora
				o un caso de soporte. Te respondemos a la brevedad.
			</p>
			<div class="mt-8 flex flex-col gap-3 sm:flex-row">
				<a href={`mailto:${email}`} class="btn btn-outline btn-lg border-neutral-content text-neutral-content">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z" />
					</svg>
					Escríbenos
				</a>
			</div>
			<p class="mt-4 text-sm opacity-70">{email}</p>
		</div>
		<div class="grid content-center gap-4">
			{canales.map((canal, index) => (
				<div class="card border border-neutral-content/15 bg-neutral-content/5" data-reveal style={`--reveal-delay: ${index * 90}ms`}>
					<div class="card-body flex-row items-center gap-4 py-5">
						<div class="rounded-box bg-primary/20 p-3 text-info">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 0 1 1.037-.443 48.282 48.282 0 0 0 5.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
							</svg>
						</div>
						<div>
							<h3 class="font-bold">{canal.title}</h3>
							<p class="text-sm opacity-70">{canal.detail}</p>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
