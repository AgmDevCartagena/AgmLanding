---
const links = [
	{ href: "#nosotros", label: "Nosotros" },
	{ href: "#servicios", label: "Servicios" },
	{ href: "#proyectos", label: "Productos" },
	{ href: "#contacto", label: "Contacto" },
];
---

<header class="navbar bg-base-100/90 backdrop-blur sticky top-0 z-50 shadow-sm">
	<div class="navbar-start">
		<div class="dropdown lg:hidden">
			<div tabindex="0" role="button" class="btn btn-ghost btn-square" aria-label="Abrir menú">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</div>
			<ul tabindex="-1" class="dropdown-content menu bg-base-100 rounded-box z-50 mt-3 w-52 p-2 shadow">
				{links.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</div>
		<a href="#inicio" class="btn btn-ghost px-2 text-xl">
			<span class="flex h-10 w-10 items-center justify-center rounded-box bg-primary text-primary-content">
				<img 
					src="./Logo.png"
					alt="Logo"
					class="h-full w-full object-contain"
				/>
			</span>
			<span class="font-bold">AGM<span class="text-primary"> Desarrollos</span></span>
		</a>
	</div>
	<div class="navbar-end">
		<ul class="menu menu-horizontal hidden px-1 font-medium lg:flex">
			{links.map((link) => (
				<li><a href={link.href}>{link.label}</a></li>
			))}
		</ul>
	</div>
</header>
